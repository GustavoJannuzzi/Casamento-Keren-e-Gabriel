# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=seu-access-token-mp
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=sua-public-key-mp
NEXT_PUBLIC_MP_WEBHOOK_URL=https://seusite.vercel.app

# Painel dos Noivos (senha simples)
NOIVOS_PASSWORD=senha_segura_aqui

# Mercado Pago — secret pra validar webhook (HMAC). Gere em: MP Developers > sua app > Webhooks
MP_WEBHOOK_SECRET=cole_o_secret_aqui

# PIX (chave pix para presentes especiais como lua de mel)
NEXT_PUBLIC_PIX_KEY=cpf-email-ou-telefone

# URL base do site (sem barra no final)
NEXT_PUBLIC_BASE_URL=https://seusite.vercel.app
